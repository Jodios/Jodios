{
    "version": "0.2.0",
    "configurations": [ 
        {
            "name": "Brave",
            "type": "chrome",
            "request": "launch",
            "runtimeExecutable": "/Applications/Brave Browser.app/Contents/MacOS/Brave Browser",
            "userDataDir": true,
            "url": "http://localhost:3000",     // create-react-app's default port 3000
            "webRoot": "${workspaceRoot}/src",
            "preLaunchTask": "npm: start"
        }
    ]
}